der="example@gmail.com" type="email" id="email" required=""/><div class="form-input-wrap"><div class="input-group no-margin"><label for="Phone">Phone</label><input class="form-input w-input" maxlength="256" name="Phone" data-name="Phone" placeholder="+1234567890" type="tel" id="Phone"/></div><div class="input-group no-margin"><label for="Field">Select service</label><select id="Field" name="Field" data-name="Field" class="form-select w-select"><option value="Another option">Select service</option><option value="">Office cleaning</option><option value="First">Window cleaning</option><option value="Second">Carpet cleaning</option><option value="Third">Bedroom cleaning</option></select></div></div><div class="form-input-wrap"><div class="input-group no-margin"><label for="Location">Location</label><input class="form-input w-input" maxlength="256" name="Location" data-name="Location" placeholder="Los angeles" type="text" id="Location"/></div><div class="input-group no-margin"><label for="Date">Date</label><input class="form-input w-input" maxlength="256" name="Date" data-name="Date" placeholder="dd-mm-yy" type="text" id="Date"/></div></div><div class="hero-form-button-wrap"><input type="submit" data-wait="Please wait..." class="button-primary-2 button-full w-button" value="Submit"/></div></form><div class="success-message w-form-done"><div>Thank you! Your submission has been received!</div></div><div class="error-message w-form-fail"><div>Oops! Something went wrong while submitting the form.</div></div></div></div></div></div></section><section class="client-section"><div class="w-layout-blockcontainer container w-container"><div data-w-id="45d47b1d-d028-7a8e-9859-b3cc29bd5ed6" class="client-marquee-wrap"><div class="client-marquee-list"><div style="-webkit-transform:translate3d(0px, 0, 0) scale3d(1, 1, 1) rotateX(0) rotateY(0) rotateZ(0) skew(0, 0);-moz-transform:translate3d(0px, 0, 0) scale3d(1, 1, 1) rotateX(0) rotateY(0) rotateZ(0) skew(0, 0);-ms-transform:translate