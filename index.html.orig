al-slider-wrap"><div data-delay="4000" data-animation="slide" class="testimonial-slider w-slider" data-autoplay="false" data-easing="ease" data-hide-arrows="false" data-disable-swipe="false" data-autoplay-limit="0" data-nav-spacing="3" data-duration="500" data-infinite="true"><div class="testimonial-mask w-slider-mask"><div class="testimonial-slide w-slide"><div class="testimonial-item"><div class="testimonial-title-wrap"><img loading="eager" src="https://cdn.prod.website-files.com/6756b988bb35f025028d3f34/6757d0dc723bb74b29c45763_star-image.svg" alt="Star Image" class="rating-image"/><h3 class="testimonial-content">The team did an outstanding job on my home. Everything was spotless, and their attention to detail was impressive.</h3></div><div class="testimonial-info"><img loading="eager" src="https://cdn.prod.website-files.com/6756b988bb35f025028d3f34/6757d0dc723bb74b29c45779_testimonial-image01.avif" alt="Testimonial Image" class="testimonial-image"/><div><h4 class="testimonial-name">Jane Doe</h4><div>Jersey City, NJ</div></div></div></div></div><div class="testimonial-slide w-slide"><div class="testimonial-item one"><div class="testimonial-title-wrap"><img loading="eager" src="https://cdn.prod.website-files.com/6756b988bb35f025028d3f34/6757d0dc723bb74b29c4576d_half-star-image.svg" alt="Star Image" class="rating-image"/><h4 class="testimonial-content">We’ve used several cleaning services, but this one is by far the best. Reliable, efficient, and always leave our office looking pristine.</h4></div><div class="testimonial-info"><img loading="eager" src="https://cdn.prod.website-files.com/6756b988bb35f025028d3f34/6757d0dc723bb74b29c45773_testimonial-image02.avif" alt="Testimonial Image" class="testimonial-image"/><div><h5 class="testimonial-name">John Smith</h5><div>New York, NY</div></div></div></div></div><div class="testimonial-slide w-slide"><div class="testimonial-item"><div class="testimonial-title-wrap"><img loading="eager" src="https://cdn.prod.website-files.com/6756b988bb35f025028d3f34/6757d0dc723bb74b29c45763_star-image.svg" alt="Star Image" class="rating-image"/><h4 class="testimonial-content">I was thrilled with the move-out cleaning service. My landlord was impressed, and I got my full deposit back!</h4></div><div class="testimonial-info"><img loading="eager" src="https://cdn.prod.website-files.com/6756b988bb35f025028d3f34/6757d0dc723bb74b29c45765_testimonial-image03.avif" alt="Testimonial Image" class="testimonial-image"/><div><h5 class="testimonial-name">Emily Johnson</h5><div>Ridgefield, NJ</div></div></div></div></div><div class="testimonial-slide w-slide"><div class="testimonial-item one"><div class="testimonial-title-wrap"><img loading="eager" src="https://cdn.prod.website-files.com/6756b988bb35f025028d3f34/6757d0dc723bb74b29c4576d_half-star-image.svg" alt="Star Image" class="rating-image"/><h4 class="testimonial-content">The cleaning team was fantastic! My home has never looked this clean. Their thoroughness and eye for detail were truly impressive.</h4></div><div class="testimonial-info"><img loading="eager" src="https://cdn.prod.website-files.com/6756b988bb35f025028d3f34/6757d0dc723bb74b29c4576f_testimonial-image04.avif" alt="Testimonial Image" class="testimonial-image"/><div><h5 class="testimonial-name">Emily Brown</h5><div>Jersey City, NJ</div></div></div></div></div><div class="testimonial-slide w-slide"><div class="testimonial-item"><div class="testimonial-title-wrap"><img loading="eager" src="https://cdn.prod.website-files.com/6756b988bb35f025028d3f34/6757d0dc723bb74b29c45763_star-image.svg" alt="Star Image" class="rating-image"/><h4 class="testimonial-content">I was blown away by the cleaning crew&#x27;s work. Every inch of my home was pristine, and their commitment to detail was remarkable.</h4></div><div class="testimonial-info"><img loading="eager" src="https://cdn.prod.website-files.com/6756b988bb35f025028d3f34/6757d0dc723bb74b29c45769_testimonial-image05.avif" alt="Testimonial Image" class="testimonial-image"/><div><h5 class="testimonial-name">Mike Johnson</h5><div>New York, NY</div></div></div></div></div></div><div class="left-arrow w-slider-arrow-left"><img loading="lazy" src="https://cdn.prod.website-files.com/6756b988bb35f025028d3f34/6757d0dc723bb74b29c45777_arrow-left.svg" alt="Arrow Icon" class="arrow"/></div><div class="right-arrow w-slider-arrow-right"><img loading="eager" src="https://cdn.prod.website-files.com/6710f912b08f2b5f7beec811/6713541b5f170efb0fbed2ce_arrow-light.svg" alt="" class="arrow"/></div><div class="hide w-slider-nav w-round w-num"></div></div></div></div></div></section><section class="video-section"><div data-poster-url="https://cdn.prod.website-files.com/6710f912b08f2b5f7beec811%2F67137b863467616e3790e77f_bg-video-poster-00001.jpg" data-video-urls="https://cdn.prod.website-files.com/6710f912b08f2b5f7beec811%2F67137b863467616e3790e77f_bg-video-transcode.mp4,https://cdn.prod.website-files.com/6710f912b08f2b5f7beec811%2F67137b863467616e3790e77f_bg-video-transcode.webm" data-autoplay="true" data-loop="true" data-wf-ignore="true" class="background-video w-background-video w-background-video-atom"><video id="eb5e5468-d1d6-e07a-e769-96293787a7da-video" autoplay="" loop="" style="background-image:url(&quot;https://cdn.prod.website-files.com/6710f912b08f2b5f7beec811%2F67137b863467616e3790e77f_bg-video-poster-00001.jpg&quot;)" muted="" playsinline="" data-wf-ignore="true" data-object-fit="cover"><source src="https://cdn.prod.website-files.com/6710f912b08f2b5f7beec811%2F67137b863467616e3790e77f_bg-video-transcode.mp4" data-wf-ignore="true"/><source src="https://cdn.prod.website-files.com/6710f912b08f2b5f7beec811%2F67137b863467616e3790e77f_bg-video-transcode.webm" data-wf-ignore="true"/></video><noscript><style>
