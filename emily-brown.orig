ocumentTouch)&&(n.className+=t+"touch")}(window,document);</script><link href="https://cdn.prod.website-files.com/6756b988bb35f025028d3f34/675825333d962c76700756b2_favicon.png" rel="shortcut icon" type="image/x-icon"/><link href="https://cdn.prod.website-files.com/6756b988bb35f025028d3f34/67582539539eb593c585ba93_webclip.png" rel="apple-touch-icon"/></head><body><div data-animation="default" data-collapse="medium" data-duration="400" data-easing="ease" data-easing2="ease" role="banner" class="navbar w-nav"><div class="container w-container"><div class="w-layout-grid grid-nav"><a href="/" id="w-node-_7dbd73bf-e274-c7d4-2781-fa51868e94ec-868e94e9" class="brand w-nav-brand"><img loading="eager" src="https://cdn.prod.website-files.com/6756b988bb35f025028d3f34/6764eb297aca189b5e2d0798_cleaninger-dark.svg" alt="" class="logo"/></a><nav role="navigation" id="w-node-_7dbd73bf-e274-c7d4-2781-fa51868e94ee-868e94e9" class="nav-menu w-nav-menu"><a href="/" class="nav-link w-nav-link">Home</a><a href="/services" class="nav-link w-nav-link">Services</a><a href="/about" class="nav-link w-nav-link">About</a><div data-delay="0" data-hover="true" data-w-id="7dbd73bf-e274-c7d4-2781-fa51868e94f5" class="dropdown w-dropdown"><div class="dropdown-toggle nav-link w-dropdown-toggle"><div class="dropdown-icon w-icon-dropdown-toggle"></div><div>Pages</div></div><nav class="dropdown-list w-dropdown-list"><a href="/" class="dropdown-link w-dropdown-link">Home </a><a href="/home-2" class="dropdown-link w-dropdown-link">Home 2</a><a href="/about" class="dropdown-link w-dropdown-link">About</a><a href="/services" class="dropdown-link w-dropdown-link">Services</a><a href="/service-static" class="dropdown-link w-dropdown-link">Service Static</a><a href="/pricing" class="dropdown-link w-dropdown-link">Pricing</a><a href="/blog" class="dropdown-link w-dropdown-link">Blog</a><a href="/contact" class="dropdown-link w-dropdown-link">Contact</a><a href="/privacy-policy" class="dropdown-link w-dropdown-link">Privacy Policy</a></nav></div></nav><div id="w-node-_7dbd73bf-e274-c7d4-2781-fa51868e950d-868e94e9" class="right-nav"><a href="/contact" data-w-id="7dbd73bf-e274-c7d4-2781-fa51868e950e" class="button-primary-1-icon mobile-hide w-inline-block"><div>Contact us</div><div class="button-primary-icon-wrap"><img loading="eager" src="https://cdn.prod.website-files.com/6756b988bb35f025028d3f34/6756c558622788afc19a5f32_arrow-icon.svg" alt="Arrow Icon" class="button-icon"/><img loading="eager" src="https://cdn.prod.website-files.com/6756b988bb35f025028d3f34/6756c558622788afc19a5f32_arrow-icon.svg" alt="Arrow Icon" class="button-hover-icon"/></div></a><div class="menu-button w-nav-button"><div class="w-icon-nav-menu"></div></div></div></div></div></div><section class="team-detail-section section-spacing-bottom"><div class="w-layout-blockcontainer container w-container"><div data-w-id="aee793da-b73b-a496-3d32-205d2a97e7fb" style="opacity:0" class="w-layout-grid grid-team-detail"><div class="team-detail-image-wrap"><img loading="eager" src="https://cdn.prod.website-files.com/6756b988bb35f025028d3f66/675830940453a61ed364feb2_team-image-02.jpg" alt="" sizes="(max-width: 479px) 94vw, (max-width: 991px) 96vw, (max-width: 1279px) 95vw, (max-width: 1919px) 96vw, 1520px" srcset="https://cdn.prod.website-files.com/6756b988bb35f025028d3f66/675830940453a61ed364feb2_team-image-02-p-500.jpg 500w, https://cdn.prod.website-files.com/6756b988bb35f025028d3f66/675830940453a61ed364feb2_team-image-02.jpg 700w" class="team-detail-image"/></div><div class="team-detail-content"><div class="team-detail-title-wrap"><div class="team-job-title">Window Cleaning Technician</div><h1 class="team-detail-title">Emily Brown</h1><p class="team-detail-description">Our Window Cleaning Technician specializes in delivering crystal-clear, streak-free windows for both residential and commercial properties.</p></div><div><div class="team-meta-item"><h2 class="team-meta-title">Phone:</h2><a href="tel:+1(555)123-4567" class="team-link">+1 (555) 123-4567</a></div><div class="team-meta-item"><h3 class="team-meta-title">Email:</h3><a href="mailto:Info@example.com" class="team-link">Info@example.com</a></div><div class="footer-social-inline"><a href="#" target="_blank" class="footer-social-link w-inline-block"><img loading="eager" src="https://cdn.prod.website-files.com/6756b988bb35f025028d3f34/6756d3d03aec6fabebc152f3_facebook.svg" alt="Facebook Icon" class="footer-social-icon"/></a><a href="#" target="_blank" class="footer-social-link w-inline-block"><img loading="eager" src="https://cdn.prod.website-files.com/6756b988bb35f025028d3f34/6756d3d03aec6fabebc152f1_instagram.svg" alt="Instagram Icon" class="footer-social-icon"/></a><a href="#" target="_blank" class="footer-social-link w-inline-block"><img loading="eager" src="https://cdn.prod.website-files.com/6756b988bb35f025028d3f34/6756d3d03aec6fabebc152f2_twitter.svg" alt="Twitter Icon" class="footer-social-icon"/></a></div></div></div></div><div data-w-id="aee793da-b73b-a496-3d32-205d2a97e818" style="opacity:0" class="team-detail"><div class="rich-text w-richtext"><p><strong>Emily Brown </strong>is our skilled Window Cleaning Technician with over 7 years of experience in the industry</p><p>Emily is renowned for her precision and dedication to leaving windows crystal clear and streak-free. Outside of her professional life, Emily enjoys rock climbing, painting, and volunteering at local shelters, showcasing her adventurous spirit and commitment to her community.</p><h5>Professional skills:</h5><ul role="list"><li><strong>Window cleaning expertise:</strong> Proficient in cleaning windows of various types and sizes, ensuring a flawless finish.</li><li><strong>Detail-oriented:</strong> Exceptional attention to detail, ensuring no streaks or smudges are left behind.</li><li><strong>Safety practices:</strong> Strong knowledge of safety procedures and equipment for high-rise and residential window cleaning.</li><li><strong>Efficiency:</strong> Skilled in completing jobs quickly and effectively without compromising quality.</li><li><strong>Customer service:</strong> Excellent communication skills to understand and fulfill client expectations.</li></ul><h5>Notable points of work:</h5><ul role="list"><li><strong>Crystal clear results:</strong> Consistently delivers windows that are spotless and streak-free.</li><li><strong>Eco-friendly methods:</strong> Utilizes environmentally safe cleaning products and practices.</li><li><strong>Specialized techniques:</strong> Expertise in various window cleaning techniques tailored to different window types and conditions.</li><li><strong>Consistent quality:</strong> Maintains a high standard of cleanliness and attention to detail in every job.</li><li><strong>Client trust:</strong> Builds strong relationships with clients through reliability and outstanding service.</li></ul></div></div></div></section><footer class="footer"><div class="container w-container"><div data-w-id="d7558fd6-59ae-df5d-4e33-ad7117a64f1d" class="w-layout-grid grid-footer"><h4 class="no-margin">Claim your free first Cleaning today.</h4><div id="w-node-d7558fd6-59ae-df5d-4e33-ad7117a64f20-17a64f1b" class="button-inline"><a href="/contact" data-w-id="ee9ec817-088f-cbd3-ff7f-9b8b0cb30061" class="button-primary-1-icon w-inline-block"><div>Claim free visit</div><div class="button-primary-icon-wrap"><img loading="eager" src="https://cdn.prod.website-files.com/6756b988bb35f025028d3f34/6756c558622788afc19a5f32_arrow-icon.svg" alt="Arrow Icon" class="button-icon"/><img loading="eager" src="https://cdn.prod.website-files.com/6756b988bb35f025028d3f34/6756c558622788afc19a5f32_arrow-icon.svg" alt="Arrow Icon" class="button-hover-icon"/></div></a><a href="tel:+1-394-495-5993" class="button-primary-1 w-button">Call us: +1-394-495-5993</a></div></div><div class="w-layout-grid grid-footer-item"><div id="w-node-d7558fd6-59ae-df5d-4e33-ad7117a64f26-17a64f1b" data-w-id="d7558fd6-59ae-df5d-4e33-ad7117a64f26" clas